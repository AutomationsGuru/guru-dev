{
  "runtimeName": "GuruHarness",
  "referenceRuntime": "a reference agent runtime",
  "skillDirectories": [
    "./skills",
    "~/.agents/skills"
  ],
  "validationCommands": [
    {
      "name": "test",
      "command": ["npm", "test"],
      "required": true
    },
    {
      "name": "typecheck",
      "command": ["npm", "run", "typecheck"],
      "required": true
    },
    {
      "name": "build",
      "command": ["npm", "run", "build"],
      "required": true
    }
  ],
  "reviewGate": {
    "provider": "coderabbit",
    "required": true,
    "command": ["coderabbit", "review", "--agent", "--type", "uncommitted"]
  },
  "approvalPolicy": {
    "autoCommitPushPr": true,
    "allowLocalMerge": false,
    "allowForcePush": false
  },
  "plannerModel": {
    "provider": "openai-compatible",
    "baseUrl": "https://api.openai.com/v1",
    "model": "gpt-5.5",
    "apiKeyEnvVar": "OPENAI_API_KEY",
    "timeoutMs": 120000,
    "temperature": 0
  },
  "plannerModelFallbacks": [],
  "runtimeHardening": {
    "allowDirtyWorkspace": false,
    "allowRiskyPaths": false,
    "plannerMaxRetries": 2,
    "riskyPathPatterns": [
      ".git",
      ".env",
      ".ssh",
      ".aws",
      ".npmrc",
      ".yarnrc",
      ".netrc",
      ".config/gcloud",
      "secrets",
      "credentials",
      "id_rsa",
      "id_ed25519",
      "service-account"
    ],
    "secretAllowList": [],
    "shellAllowlist": ["npm", "node", "git", "pwsh", "coderabbit"]
  },
  "selfBuild": {
    "maxIterations": 1,
    "completedTaskIds": []
  },
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000,
    "summaryMaxTokens": 2048
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "maxRetries": 0,
      "maxRetryDelayMs": 60000
    }
  },
  "swarm": {
    "maxConcurrentWorkers": 3,
    "workerToolCallBudget": 8,
    "workerTimeoutMs": 120000,
    "ultraSwarm": false,
    "maxTasksPerSession": 64
  },
  "lookahead": {
    "enabled": false,
    "forkWidth": 3,
    "leadDepth": 2,
    "scoutBudgetFraction": 0.25
  }
}
